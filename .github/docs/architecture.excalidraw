    {
      "id": "EwryclQecrmU_fY4GXy14",
      "type": "text",
      "x": -1569.3848454347317,
      "y": -1914.9059409570395,
      "width": 649,
      "height": 50,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
