      "seed": 851909047,
      "version": 119,
      "versionNonce": 369394553,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780843054218,
      "link": null,
      "locked": false,
      "text": "When an enterprise system crashes, the standard response is\na chaotic, 30-person \"War Room\" bridge call.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "When an enterprise system crashes, the standard response is a chaotic, 30-person \"War Room\" bridge call.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "1-WRb2XcbKsTUMl2_wqzR",
      "type": "text",
      "x": -1569.561938940591,
      "y": -1854.580394692391,
      "width": 583,
      "height": 75,
      "angle": 0,
      "strokeColor": "#f08c00",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": "YHGh-cOsjByDhtFED4WOC",
      "index": "b64O",
      "roundness": null,
      "seed": 337232185,
      "version": 116,
      "versionNonce": 762817625,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1780843054218,
      "link": null,
      "locked": false,
      "text": "Silos of data: Support is looking at Jira, DevOps is\nlooking at GitHub, and Infra is digging through Azure\ntelemetry.",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Silos of data: Support is looking at Jira, DevOps is looking at GitHub, and Infra is digging through Azure telemetry.",
      "autoResize": false,
      "lineHeight": 1.25
